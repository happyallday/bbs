# 数据库配置
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=bbs
MYSQL_USER=bbs_user
MYSQL_PASSWORD=bbs_password

# Redis配置
REDIS_PASSWORD=

# JWT密钥
JWT_SECRET=BBS2024JWTSECRETKEYFORAUTHENTICATIONANDAUTHORIZATION

# 企业微信配置
WECHAT_CORP_ID=your_corp_id
WECHAT_AGENT_ID=1000001
