# 应用配置
SERVER_PORT=8080

# 文件上传配置
FILE_UPLOAD_PATH=/data/uploads/
FILE_MAX_SIZE=10485760

# 网络访问配置
NETWORK_ENABLE_IP_CHECK=true
NETWORK_EXTERIOR_PATHS=/home,/public